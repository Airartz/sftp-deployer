{
  "name": "sftp-deployer",
  "version": "1.2.1",
  "description": "Intelligent SFTP deployment tool for V-Servers",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node -e \"if(process.platform!=='win32'){var e=require('child_process').execSync;try{e('chmod +x node_modules/.bin/*',{stdio:'ignore'})}catch(x){}try{e('find node_modules -name \\\"app-builder_*\\\" -exec chmod +x {} ;',{stdio:'ignore'})}catch(x){}}\"",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npx @electron/rebuild -v 28.3.3 --arch arm64 && npm run build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "chokidar": "^3.6.0",
    "date-fns": "^3.6.0",
    "ignore": "^5.3.1",
    "p-limit": "^3.1.0",
    "sql.js": "^1.12.0",
    "ssh2-sftp-client": "^10.0.3",
    "uuid": "^10.0.0",
    "webdav": "^4.11.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "jimp": "^0.22.12",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.sftp-deployer.app",
    "productName": "SFTP Deployer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false,
      "icon": "resources/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.png",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "afterPack": "./scripts/afterPack.js",
    "dmg": {
      "title": "SFTP Deployer",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "resources/icons/icon.ico",
        "to": "icons/icon.ico"
      },
      {
        "from": "resources/icons/icon.png",
        "to": "icons/icon.png"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ssh2/**/*",
      "!**/cpu-features/**"
    ],
    "npmRebuild": false
  }
}
